# скопируйте в .env и заполните значения. в репозиторий не коммитить.

SECRET_KEY=your-secret-key-min-32-chars

# вариант 1: postgresql (рекомендуется для продакшена и сдачи диплома)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/dbname
# вариант 2: mysql
DATABASE_URL=mysql+pymysql://user:password@localhost/dbname
# вариант 3: локальная разработка без сервера бд
# DATABASE_URL=sqlite:///app.db

FLASK_APP=run.py
FLASK_DEBUG=0
SESSION_COOKIE_SECURE=0

# демо-администратор для seed_data.py. для реального запуска задайте свои значения.
ADMIN_EMAIL=admin@altay.local
ADMIN_PASSWORD=change-this-admin-password

# ключ для закрытого api интеграций (1с и т.п.)
INTEGRATION_API_KEY=your-api-key
